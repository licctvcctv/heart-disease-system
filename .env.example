# Project
PROJECT_NAME=heart-disease-system
TZ=Asia/Shanghai

# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SETTINGS_MODULE=config.settings

# Database
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=heart_disease
MYSQL_USER=heart_user
MYSQL_PASSWORD=heart_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://heart_user:heart_password@mysql:3306/heart_disease

# Frontend
# Empty means frontend resolves http://<current-host>:8000/api at runtime.
VITE_API_BASE_URL=
VITE_API_TIMEOUT_MS=30000

# Data locations for offline ingestion and model training
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
MODEL_DIR=./data/models
ML_MODEL_DIR=./ml/artifacts/production/kaggle_2020_full
UCI_DATASET_DIR=./data/raw/uci
KAGGLE_DATASET_DIR=./data/raw/kaggle

# Python ML
ML_RANDOM_SEED=42
ML_MODEL_NAME=logistic_regression
ML_TEST_SIZE=0.2

# Offline ADS query source for Django. Keep mysql for normal page/API reads.
ANALYTICS_QUERY_ENGINE=mysql

# Hive / Hadoop ADS warehouse, used only when refreshing offline MySQL ADS tables.
HIVE_HOST=192.168.6.129
HIVE_PORT=10000
HIVE_USER=root1
HIVE_AUTH=NONE
HIVE_DATABASE=heart_disease_system
HDFS_URI=hdfs://master-Zb24621219:9000

# MySQL offline ADS tables read by Django.
ADS_MYSQL_HOST=mysql
ADS_MYSQL_PORT=3306
ADS_MYSQL_DATABASE=heart_disease
ADS_MYSQL_USER=heart_user
ADS_MYSQL_PASSWORD=heart_password
