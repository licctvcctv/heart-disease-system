[Unit]
Description=Heart Disease Vue Static Frontend
After=network.target heart-disease-backend.service
Wants=heart-disease-backend.service

[Service]
Type=simple
User=root1
Group=root1
WorkingDirectory=/home/root1/heart-disease-system/frontend/vue3-app/dist
ExecStart=/usr/bin/python3 -m http.server 4173 --bind 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
